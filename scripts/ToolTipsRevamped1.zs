<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.darkRed("NOTES:"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  This is a placeholder item representing a safe way to build the interior of a Salt reactor for Lymph"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  This item has three multiblock preview recipes"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  1. The blocks arrangement for a single slice of the reactor interior, that can be extended up to 14 blocks"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  2. What fluids to place in each Vessel and Heater"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  3. An example for a longer design"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  Here is how it works:"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  - NaK and Fuel flow in opposite directions:"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("      * NaK fluids of different types come into the Coolant Heaters on the purple side"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("      * Hot NaK fluids of different types come out of the Coolant Heaters on the red side"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("      * The fuel (Ogerite, etc) comes into the Fission Vessels on the red side"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("      * Lymph of Pixonia comes out of the Fission Vessels on the purple side"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  - If a design is longer than one slice, only the last slice on either end uses DEPLETED OUT and HOT COOLANT OUT, all other slices use COOLANT SPREAD and FUEL SPREAD"));





<nuclearcraft:salt_fission_vent>.addTooltip(format.gold("Use:"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  Variable size multiblock, with the following outside structure (see preview):"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  - Controller needs to be on a face"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  - Faces can be Salt Reactor Glass or Salt reactor Wall"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  - Edges have to be Salt Reactor Frame"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  - Locations where fluids are transfered in and out use Salt Reactor Vents"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  The interior of the Reactor is composed of Molten Salt Fission Vessels and Coolant Meaters"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.gold("Tips:"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  JEI shows multiblock previews for safe Salt Reactor designs for each fuel"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  These previews show a single slice that can be extended up to 14 blocks"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  The blocks in these previews are placeholders for the fluids running through the Vessels and Coolant Heaters"));


