<modularmachinery:blockmeitemoutputbus>.addTooltip(format.gold("Use:"));
<modularmachinery:blockmeitemoutputbus>.addTooltip(format.yellow("  Automatically pushes a multiblock's output to the AE2 network it's connected to"));
<modularmachinery:blockmeitemoutputbus>.addTooltip(format.darkRed("NOTES:"));
<modularmachinery:blockmeitemoutputbus>.addTooltip(format.red("  Best if used on subnets, and even there it is a bit laggy"));
<modularmachinery:blockmeitemoutputbus>.addTooltip(format.red("  In most cases a large enough output bus and an Import Interface with low polling rate is more performant"));


<modularmachinery:blockmefluidoutputbus>.addTooltip(format.gold("Use:"));
<modularmachinery:blockmefluidoutputbus>.addTooltip(format.yellow("  Automatically pushes a multiblock's output to the AE2 network it's connected to"));
<modularmachinery:blockmefluidoutputbus>.addTooltip(format.darkRed("NOTES:"));
<modularmachinery:blockmefluidoutputbus>.addTooltip(format.red("  Best if used on subnets, and even there it is a bit laggy"));
<modularmachinery:blockmefluidoutputbus>.addTooltip(format.red("  In most cases a large enough output hatch and an Import Interface with low polling rate is more performant"));

