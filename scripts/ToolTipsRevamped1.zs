<extrautils2:interactionproxy>.addTooltip(format.gold("Use:"));
<extrautils2:interactionproxy>.addTooltip(format.yellow("  Place in front of a Mechanical user or Miner to change their area of effect"));



<extrautils2:user>.addTooltip(format.gold("Use:"));
<extrautils2:user>.addTooltip(format.yellow("  Fake Player that can right or left click items in its inventory, affecting the block or entity right in front of it"));
<extrautils2:user>.addTooltip(format.yellow("  Depending on the item being used, or the block you want to click, there are multiple functions available"));
<extrautils2:user>.addTooltip(format.yellow("  When in doubt, try them all ;)"));
<extrautils2:user>.addTooltip(format.yellow("  - Generic Click"));
<extrautils2:user>.addTooltip(format.yellow("  - Place Block"));
<extrautils2:user>.addTooltip(format.yellow("  - Use Item on Block"));
<extrautils2:user>.addTooltip(format.yellow("  - Activate Block WIth Item"));
<extrautils2:user>.addTooltip(format.yellow("  - Use Item"));
<extrautils2:user>.addTooltip(format.yellow("  - Entity"));
<extrautils2:user>.addTooltip(format.gold("Tips:"));
<extrautils2:user>.addTooltip(format.yellow("  To affect a larger area with multiple blocks, use an Ender Porcupine"));

<extrautils2:miner>.addTooltip(format.gold("Use:"));
