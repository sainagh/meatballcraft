<extrautils2:miner>.addTooltip(format.yellow("  To affect a larger area with multiple blocks, use an Ender Porcupine"));









<actuallyadditions:block_phantomface>.addTooltip(format.gold("Use:"));
<actuallyadditions:block_phantomface>.addTooltip(format.yellow("  Allows item transfer at a distance"));
<actuallyadditions:block_phantomface>.addTooltip(format.yellow("  Use the phantom connector to bind to a machine within 16 blocks"));
<actuallyadditions:block_phantomface>.addTooltip(format.yellow("  Place a phantom booster on top to increase range (one for 32 blocks, two for 64, three for 128)"));
<actuallyadditions:block_phantomface>.addTooltip(format.darkRed("NOTES:"));
<actuallyadditions:block_phantomface>.addTooltip(format.red("  The Transvector Interface is less laggy, and does the same thing"));
<actuallyadditions:block_phantomface>.addTooltip(format.darkRed("WARNINGS:"));
<actuallyadditions:block_phantomface>.addTooltip(format.red("  Do not place right next to modular machinery hatches"));


