<contenttweaker:ogerite_vital_vessel>.addTooltip(format.darkRed("NOTES:"));
<contenttweaker:ogerite_vital_vessel>.addTooltip(format.red("  This is a placeholder block representing a Fission vessel filled with Ogerite or its upgrades"));
<contenttweaker:ogerite_vital_vessel>.addTooltip(format.red("  "));
<contenttweaker:ogerite_vital_vessel>.addTooltip(format.red("  For a one-slice design, it should be configured as follows:"));
<contenttweaker:ogerite_vital_vessel>.addTooltip(format.red("  - DEFAULT on side where Fuel comes in (and NaK comes out)"));
<contenttweaker:ogerite_vital_vessel>.addTooltip(format.red("  - DEPLETED OUT on side where Fuel comes out (and NaK comes in)"));
<contenttweaker:ogerite_vital_vessel>.addTooltip(format.red("  "));
<contenttweaker:ogerite_vital_vessel>.addTooltip(format.red("  For a multi slice design, it should be configured as follows:"));
<contenttweaker:ogerite_vital_vessel>.addTooltip(format.red("  - DEFAULT on side where fuel comes in (and NaK comes out)"));
<contenttweaker:ogerite_vital_vessel>.addTooltip(format.red("  - FUEL SPREAD on direction where fuel is moving to the next slice"));
<contenttweaker:ogerite_vital_vessel>.addTooltip(format.red("  - DEPLETED OUT on side where fuel comes out (and NaK comes in)"));

