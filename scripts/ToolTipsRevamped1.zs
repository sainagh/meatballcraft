<actuallyadditions:block_phantom_breaker>.addTooltip(format.gold("Tips:"));
<actuallyadditions:block_phantom_breaker>.addTooltip(format.yellow("  For breaking a small number of blocks, you can use a Mechanical Miner with an Ender Porcupine"));
<actuallyadditions:block_phantom_breaker>.addTooltip(format.yellow("  For breaking a large number of blocks, you can use a Builder with a Quarry Card"));







<botania:spreader:0>.addTooltip(format.gold("Use:"));
<botania:spreader:0>.addTooltip(format.yellow("  Transfers mana between Botania blocks with mana storage (flowers, pools, etc.)"));
<botania:spreader:0>.addTooltip(format.yellow("  To bind input:"));
<botania:spreader:0>.addTooltip(format.yellow("  - Generating Flowers placed near a Spreader will automatically connect to it"));
<botania:spreader:0>.addTooltip(format.yellow("  - You can also use the wand of the Forest, Shift + Right Click the flower (first), and then the spreader (second) to bind them"));
<botania:spreader:0>.addTooltip(format.yellow("  - A Mana Pool will automatically output to a Spreader next to it"));
<botania:spreader:0>.addTooltip(format.yellow("  To bind output:"));
<botania:spreader:0>.addTooltip(format.yellow("  - With a Wand of the Forest, Shift + Right Click the spreader (first), and then the output block (second)"));
<botania:spreader:0>.addTooltip(format.gold("Tips:"));
<botania:spreader:0>.addTooltip(format.yellow("  Spreaders are recommended to transfer mana from/to Flowers, and to Runic Altars"));
<botania:spreader:0>.addTooltip(format.yellow("  To move Mana between Pools, and to the Terrestrial Agglomeration Plane, Sparks are recommended"));
<botania:spreader:0>.addTooltip(format.gold("Info:"));
<botania:spreader:0>.addTooltip(format.yellow("  Holds 1000 mana"));
<botania:spreader:0>.addTooltip(format.yellow("  Sends 160 mana per burst"));
<botania:spreader:0>.addTooltip(format.yellow("  Burst travels 4 blocks per second"));
<botania:spreader:0>.addTooltip(format.yellow("  Burst travels 12 blocks, or 3 seconds, before losing mana"));
<botania:spreader:0>.addTooltip(format.yellow("  Burst loses 4 mana/t"));
<botania:spreader:0>.addTooltip(format.white("------------------"));
<botania:spreader:0>.addTooltip(format.green("Thanks to koos for compiling spreader stats!"));

