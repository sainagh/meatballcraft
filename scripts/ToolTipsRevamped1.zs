<contenttweaker:server_rack>.addTooltip(format.yellow("  - Open the questbook, K by default or using the Questbook item you received"));
<contenttweaker:server_rack>.addTooltip(format.yellow("  - Go to the home page, the one with the pack logo, click 'back' in the bottom right to get there"));
<contenttweaker:server_rack>.addTooltip(format.yellow("  - Click on 'Party', and create your party"));
<contenttweaker:server_rack>.addTooltip(format.yellow("  - Invite your friends!"));
<contenttweaker:server_rack>.addTooltip(format.yellow("  - Note that each player will still have to complete the checkbox quests manually before progress is shared"));
<contenttweaker:server_rack>.addTooltip(format.yellow("  To start a team for shared chunks and EMC:"));
<contenttweaker:server_rack>.addTooltip(format.yellow("  - Open your inventory, and click the 'My Team' button on the top right, showing three colored people"));
<contenttweaker:server_rack>.addTooltip(format.yellow("  - Click 'Create a New Team', and invite your friends!"));
<contenttweaker:server_rack>.addTooltip(format.yellow("  - In 'Settings', you can chance chunk and EMC sharing options"));















