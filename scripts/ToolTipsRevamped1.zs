<nuclearcraft:salt_fission_vessel>.addTooltip(format.gold("用法："));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  在熔盐反应堆内作为流体管道工作，用以处理燃料"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  右击各个面进行配置"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  对已配置的容器Shift+右击放置新容器时，可复制其配置"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.gold("每个面的设置："));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  - 默认：输入流体"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  - 燃料分配：将输入流体传输至其他容器，用于将多个相邻容器串联成链"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  - 枯竭输出：将输出流体从容器链中移出，用作链中最终容器的输出端"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  - 禁用：不传输流体，用于接触反应堆外壁或冷却剂加热器的面"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.gold("提示："));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  JEI中显示有每种燃料的安全熔盐反应堆设计的多方块预览"));
