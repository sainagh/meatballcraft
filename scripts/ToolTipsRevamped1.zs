<contenttweaker:chunky_sand_pile>.addTooltip(format.gold("Tips:"));
<contenttweaker:chunky_sand_pile>.addTooltip(format.yellow("  - Chunk loading in Meatballcraft is not handled through blocks, it uses FTB Utilities"));
<contenttweaker:chunky_sand_pile>.addTooltip(format.yellow("  - To load chunks, click the 'Claim Chunks' button on the top right on your inventory, it looks like a map"));
<contenttweaker:chunky_sand_pile>.addTooltip(format.yellow("  - Left Click and drag to claim chunks"));
<contenttweaker:chunky_sand_pile>.addTooltip(format.yellow("  - Shift Left Click and drag claimed chunks to enable chunk loading"));
<contenttweaker:chunky_sand_pile>.addTooltip(format.yellow("  - Right Click and drag claimed or loaded chunks to remove claim and loading"));


