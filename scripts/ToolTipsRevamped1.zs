<draconicevolution:reactor_core>.addTooltip(format.gold("Use:"));
<draconicevolution:reactor_core>.addTooltip(format.yellow("  To build a Draconic Reactor you need: 1 Core, 4 Stabilizers, 1 Injector"));
<draconicevolution:reactor_core>.addTooltip(format.yellow("  Core is placed in the center, with the Stabilizers 4 blocks apart from the Core, and the Injector 4 blocks below the Core"));
<draconicevolution:reactor_core>.addTooltip(format.yellow("  The Injector needs energy from the bottom"));
<draconicevolution:reactor_core>.addTooltip(format.yellow("  Place 8 blocks of Awakened Draconium in the Injector, and press 'Charge'"));
<draconicevolution:reactor_core>.addTooltip(format.yellow("  From there, you can configure its operation control"));
<draconicevolution:reactor_core>.addTooltip(format.gold("Tips:"));
<draconicevolution:reactor_core>.addTooltip(format.yellow("  The reactor causes a big explosion if it goes unstable"));
<draconicevolution:reactor_core>.addTooltip(format.yellow("  Breaking the Stabilizers in a running reactor makes it unstable"));
<draconicevolution:reactor_core>.addTooltip(format.white("------------------"));
<draconicevolution:reactor_core>.addTooltip(format.green("Thanks to Connor for making Draconic Alchemy! Big booms are on the way!"));

