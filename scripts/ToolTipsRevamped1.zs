<contenttweaker:helpful_tippy_hat>.addTooltip(format.aqua("  - Blue and light blue text explains how to obtain a given item, or gives hints for puzzles"));
<contenttweaker:helpful_tippy_hat>.addTooltip(format.yellow("  - Yellow text explains how a given item or machine is used, and gives tips and tricks"));
<contenttweaker:helpful_tippy_hat>.addTooltip(format.red("  - Red indicates important things, like a bug or a suggested behavior"));
<contenttweaker:helpful_tippy_hat>.addTooltip(format.red("  - Tooltips with the old format are entirely red, these are slowly being changed"));
<contenttweaker:helpful_tippy_hat>.addTooltip(format.green("  - Green is for flavor text and 'Reusable' markers"));
<contenttweaker:helpful_tippy_hat>.addTooltip(format.white("------------------"));
<contenttweaker:helpful_tippy_hat>.addTooltip(format.red("Thanks to NerdySpider for the texture!"));




