<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.darkRed("注意："));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  这是一个占位物品，代表一种用于产出光精界淋巴液的熔盐反应堆内部结构的安全搭建方式"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  该物品拥有三种多方块结构预览配方"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  1. 反应堆内部单片层的方块布局，最多可重复延伸14层"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  2. 每个容器和加热器中应放置的流体"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  3. 较长设计的示例"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  工作原理如下："));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  - 钠钾流体与燃料流向相反："));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("      * 不同类型的钠钾流体从紫色面进入冷却剂加热器"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("      * 不同类型的热钠钾流体从红色面离开冷却剂加热器"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("      * 燃料（如食人魔金属等）从红色面进入裂变容器"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("      * 光精界淋巴液从紫色面离开裂变容器"));
<contenttweaker:safe_lymph_of_pixonia>.addTooltip(format.red("  - 如果设计超过单片层，只有两端最外侧的片层使用'耗尽输出'和'热冷却液输出'，所有其他片层使用'冷却液分配'和'燃料分配'"));





<nuclearcraft:salt_fission_vent>.addTooltip(format.gold("用法："));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  可变尺寸的多方块结构，外部结构需满足以下条件（见预览）："));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  - 控制器需位于某一面"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  - 各面可由熔盐反应堆外壳或熔盐反应堆玻璃构成"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  - 棱边必须为熔盐反应堆框架"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  - 流体输入输出的位置使用熔盐反应堆出入口"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  反应堆内部由熔盐裂变容器和冷却剂加热器组成"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.gold("提示："));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  JEI中显示有每种燃料的安全熔盐反应堆设计的多方块预览"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  这些预览展示的是单个片层，该片层最多可重复延伸14层"));
<nuclearcraft:salt_fission_vent>.addTooltip(format.yellow("  预览中的方块是流经容器和冷却剂加热器的流体的占位方块"));


