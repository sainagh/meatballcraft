<nuclearcraft:salt_fission_vessel>.addTooltip(format.gold("Use:"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  Works like a fluid pipe inside a salt reactor, to process fuels"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  Click on each face to configure it"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  Shift + click on a configured Vessel to place another Vessel with the same configuration"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.gold("Settings for each face:"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  - DEFAULT: input fluids"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  - FUEL SPREAD: moves input fluid to other vessels, used to connect multiple adjacent vessels into a chain"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  - DEPLETED OUT: moves output fluid to out of a Vessel chain, used as the output of the final vessel in a chain"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  - DISABLED: fluid is not transfered, used for faces touching the walls of a reactor, or touching Coolant Heaters"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.gold("Tips:"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  JEI shows multiblock previews for safe Salt Reactor designs for each fuel"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  These previews show a single slice that can be extended up to 14 blocks"));
<nuclearcraft:salt_fission_vessel>.addTooltip(format.yellow("  The blocks in these previews are placeholders for the fluids running through the Vessels and Coolant Heaters"));

<nuclearcraft:salt_fission_heater>.addTooltip(format.gold("Use:"));
<nuclearcraft:salt_fission_heater>.addTooltip(format.yellow("  Works like a fluid pipe inside a salt reactor, to process NaK Coolants"));
<nuclearcraft:salt_fission_heater>.addTooltip(format.yellow("  Click on each face to configure it"));
<nuclearcraft:salt_fission_heater>.addTooltip(format.yellow("  Shift + click on a configured Coolant Heater to place another Coolant Heater with the same configuration"));
<nuclearcraft:salt_fission_heater>.addTooltip(format.gold("Settings for each face:"));
<nuclearcraft:salt_fission_heater>.addTooltip(format.yellow("  - DEFAULT: input fluids"));
<nuclearcraft:salt_fission_heater>.addTooltip(format.yellow("  - COOLANT SPREAD: moves input fluid to other heaters, used to connect multiple adjacent heaters into a chain"));
<nuclearcraft:salt_fission_heater>.addTooltip(format.yellow("  - HOT COOLANT OUT: moves output fluid to out of a Coolant Heater chain, used as the output of the final heater in a chain"));
<nuclearcraft:salt_fission_heater>.addTooltip(format.yellow("  - DISABLED: fluid is not transfered, used for faces touching the walls of a reactor, or touching Fuel Vessels"));
<nuclearcraft:salt_fission_heater>.addTooltip(format.gold("Tips:"));
<nuclearcraft:salt_fission_heater>.addTooltip(format.yellow("  JEI shows multiblock previews for safe Salt Reactor designs for each fuel"));
<nuclearcraft:salt_fission_heater>.addTooltip(format.yellow("  These previews show a single slice that can be extended up to 14 blocks"));
<nuclearcraft:salt_fission_heater>.addTooltip(format.yellow("  The blocks in these previews are placeholders for the fluids running through the Vessels and Coolant Heaters"));



