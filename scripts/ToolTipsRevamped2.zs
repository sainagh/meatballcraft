<bigreactors:reactorglass>.addTooltip(format.gold("用法："));
<bigreactors:reactorglass>.addTooltip(format.yellow("  尺寸可变的多方块结构（见预览）"));
<bigreactors:reactorglass>.addTooltip(format.yellow("  外部结构需满足以下条件："));
<bigreactors:reactorglass>.addTooltip(format.yellow("  - 控制器需位于某一侧面"));
<bigreactors:reactorglass>.addTooltip(format.yellow("  - 侧面可由黄铀反应堆外壳或黄铀反应堆玻璃构成"));
<bigreactors:reactorglass>.addTooltip(format.yellow("  - 棱边必须为黄铀反应堆外壳"));
<bigreactors:reactorglass>.addTooltip(format.yellow("  - 输入黄铀的位置必须为输入模式（黄色）的访问端口"));
<bigreactors:reactorglass>.addTooltip(format.yellow("  - 输出蓝晶的位置必须为输出模式（蓝色）的访问端口"));
<bigreactors:reactorglass>.addTooltip(format.yellow("  - 输出能量的位置必须为能量端口"));
<bigreactors:reactorglass>.addTooltip(format.yellow("  - 燃料棒柱上方必须为控制杆"));
<bigreactors:reactorglass>.addTooltip(format.yellow("  内部结构需满足以下条件："));
<bigreactors:reactorglass>.addTooltip(format.yellow("  - 燃料棒竖直排列成柱；燃料棒柱越多，燃料消耗越快"));
<bigreactors:reactorglass>.addTooltip(format.yellow("  - 在竖直柱中间放置以下方块，数量越多，每个锭产出的RF越多"));
<bigreactors:reactorglass>.addTooltip(format.yellow("  龙块、末影块、极寒之凛冰、红石琥珀金块"));


